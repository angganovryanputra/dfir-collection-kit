      "artifact_id": "linux_journalctl",
      "name": "systemd Journal",
      "os": "linux",
      "category": "logs",
      "priority": "high",
      "why_important": "Systemd journal aggregates system and service logs, crucial for incident timelines.",
      "paths": [
        {"path": "/var/log/journal", "notes": "Persistent journal storage (if enabled)"},
        {"path": "/run/log/journal", "notes": "Runtime journal storage"}
      ],
      "collection_method": {
        "type": "command",
        "recommended": "journalctl --no-pager --since '-7 days'",
        "fallbacks": ["Copy journal files if accessible"]
      },
      "version_notes": ["systemd-based distributions"],
      "source_citations": [
        {
          "title": "journalctl",
          "publisher": "systemd",
          "url": "https://www.freedesktop.org/software/systemd/man/latest/journalctl.html",
          "section": "DESCRIPTION and OPTIONS"
        },
        {
          "title": "systemd-journald.service",
          "publisher": "systemd",
          "url": "https://www.freedesktop.org/software/systemd/man/latest/systemd-journald.service.html",
          "section": "Journal storage"
        }
      ]
    },
