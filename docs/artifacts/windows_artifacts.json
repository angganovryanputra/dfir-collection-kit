    {
      "artifact_id": "windows_scheduled_tasks",
      "name": "Scheduled Tasks",
      "os": "windows",
      "category": "persistence",
      "priority": "high",
      "why_important": "Tasks can execute at logon or boot and are commonly abused for persistence.",
      "paths": [
        {
          "path": "%SystemRoot%\\System32\\Tasks",
          "notes": "Task definitions stored as files"
        }
      ],
      "collection_method": {
        "type": "command",
        "recommended": "schtasks /query /fo LIST /v",
        "fallbacks": ["Copy task XML files from Task folder"]
      },
      "version_notes": ["Task schema stable across Windows 10/11"],
      "source_citations": [
        {
          "title": "Task Scheduler Schema",
          "publisher": "Microsoft",
          "url": "https://learn.microsoft.com/en-us/windows/win32/taskschd/task-scheduler-schema",
          "section": "Task definitions and triggers"
        },
        {
          "title": "Scheduled Task/Job: Scheduled Task",
          "publisher": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1053/005/",
          "section": "Abuse of scheduled tasks"
        }
      ]
    },
    {
      "artifact_id": "windows_wmi_event_subscriptions",
      "name": "WMI Event Subscriptions",
      "os": "windows",
      "category": "persistence",
      "priority": "medium",
      "why_important": "WMI event filters/consumers/bindings are stealthy persistence mechanisms.",
      "paths": [
        {
          "path": "root\\subscription (WMI repository)",
          "notes": "__EventFilter, __EventConsumer, __FilterToConsumerBinding"
        }
      ],
      "collection_method": {
        "type": "command",
        "recommended": "Get-CimInstance -Namespace root\\subscription -Class __EventFilter/__EventConsumer/__FilterToConsumerBinding",
        "fallbacks": ["Collect Sysmon Event IDs 19-21 if available"]
      },
      "version_notes": ["Requires WMI access; may need elevated privileges"],
      "source_citations": [
        {
          "title": "Event Triggered Execution: Windows Management Instrumentation Event Subscription",
          "publisher": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1546/003/",
          "section": "Event filters, consumers, bindings"
        },
        {
          "title": "Sysmon",
          "publisher": "Microsoft Sysinternals",
          "url": "https://learn.microsoft.com/en-us/sysinternals/downloads/sysmon",
          "section": "Event ID 19/20/21 (WMI)"
        }
      ]
    },
