{
  "artifacts": [
    {
      "artifact_id": "windows_eventlog_security",
      "name": "Windows Security Event Log",
      "os": "windows",
      "category": "logs",
      "priority": "high",
      "why_important": "Contains authentication, logon, process creation, and audit events critical for incident timelines.",
      "paths": [
        {
          "path": "%SystemRoot%\\System32\\winevt\\Logs\\Security.evtx",
          "notes": "Default Security.evtx location"
        }
      ],
      "collection_method": {
        "type": "export",
        "recommended": "wevtutil epl Security <out.evtx> /q:*[System[TimeCreated[timediff(@SystemTime) <= <ms>]]]",
        "fallbacks": ["Copy Security.evtx if export fails and file is readable"]
      },
      "version_notes": ["Windows 10/11, Server 2016+ consistent log channel name"],
      "source_citations": [
        {
          "title": "Eventlog Key",
          "publisher": "Microsoft",
          "url": "https://learn.microsoft.com/en-us/windows/win32/eventlog/eventlog-key",
          "section": "Eventlog Key table (Application/Security/System)"
        },
        {
          "title": "4624(S): An account was successfully logged on",
          "publisher": "Microsoft",
          "url": "https://learn.microsoft.com/en-us/previous-versions/windows/it-pro/windows-10/security/threat-protection/auditing/event-4624",
          "section": "Logon types and descriptions"
        }
      ]
    },
