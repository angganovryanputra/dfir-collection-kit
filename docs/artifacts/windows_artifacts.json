    {
      "artifact_id": "windows_registry_run_keys",
      "name": "Run and RunOnce Registry Keys",
      "os": "windows",
      "category": "persistence",
      "priority": "high",
      "why_important": "Common autostart mechanism for persistence.",
      "paths": [
        {"path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", "notes": "Machine-wide"},
        {"path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce", "notes": "Machine-wide"},
        {"path": "HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Run", "notes": "Per-user"},
        {"path": "HKCU\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\RunOnce", "notes": "Per-user"}
      ],
      "collection_method": {
        "type": "command",
        "recommended": "reg query <key>",
        "fallbacks": []
      },
      "version_notes": ["Consistent across modern Windows versions"],
      "source_citations": [
        {
          "title": "Run and RunOnce Registry Keys",
          "publisher": "Microsoft",
          "url": "https://learn.microsoft.com/en-us/windows/win32/setupapi/run-and-runonce-registry-keys",
          "section": "Run and RunOnce keys"
        },
        {
          "title": "Boot or Logon Autostart Execution: Registry Run Keys / Startup Folder",
          "publisher": "MITRE ATT&CK",
          "url": "https://attack.mitre.org/techniques/T1547/001/",
          "section": "Registry Run Keys / Startup Folder"
        }
      ]
    },
    {
      "artifact_id": "windows_startup_folders",
      "name": "Startup Folders",
      "os": "windows",
      "category": "persistence",
      "priority": "high",
      "why_important": "Startup folders are common persistence targets for user and all-users startup.",
      "paths": [
        {
          "path": "%APPDATA%\\Microsoft\\Windows\\Start Menu\\Programs\\Startup",
          "notes": "Per-user startup folder"
        },
        {
          "path": "%ProgramData%\\Microsoft\\Windows\\Start Menu\\Programs\\Startup",
          "notes": "All-users startup folder"
        }
      ],
      "collection_method": {
        "type": "copy",
        "recommended": "List and copy items from Startup folders",
        "fallbacks": ["Record folder listing if files are locked"]
      },
      "version_notes": ["Paths derived from CSIDL/known folder mapping"],
      "source_citations": [
        {
          "title": "CSIDL values",
          "publisher": "Microsoft",
          "url": "https://learn.microsoft.com/en-us/windows/win32/shell/csidl",
