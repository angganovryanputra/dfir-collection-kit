# DFIR Rapid Collection Kit - Environment Configuration
# Copy this file to .env and configure values before running

# ==============================================================================
# Backend Configuration
# ==============================================================================

# Database connection URL
# For Docker (recommended): postgresql+asyncpg://dfir:dfir@db:5432/dfir
# For local dev: postgresql+asyncpg://dfir:password@localhost:5432/dfir
DATABASE_URL=postgresql+asyncpg://dfir:dfir@db:5432/dfir

# Secret key for JWT token signing (REQUIRED for production)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Never use the default "change-me" in production!
SECRET_KEY=local-dev-secret

# Agent shared secret for agent authentication (REQUIRED)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Must match agent configuration
AGENT_SHARED_SECRET=local-agent-secret

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Path to store evidence files
EVIDENCE_STORAGE_PATH=/vault/evidence

# Maximum evidence upload size in megabytes
MAX_UPLOAD_SIZE_MB=10240

# Require authentication for API endpoints
# Set to false ONLY for local development
REQUIRE_AUTH=true

# Allowed CORS origins for frontend
# For Docker: http://localhost:5173
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# ==============================================================================
# Frontend Configuration
# ==============================================================================

# Backend API base URL
# For Docker (recommended): http://backend:8000/api/v1
# For local dev: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://backend:8000/api/v1

# ==============================================================================
# Production Notes
# ==============================================================================
#
# 1. SECRET_KEY and AGENT_SHARED_SECRET must be set to strong random values
# 2. REQUIRE_AUTH should always be true in production
# 3. ALLOWED_ORIGINS should be set to your actual frontend domain
# 4. Evidence storage should be backed up regularly
# 5. Consider using external object storage for large deployments
