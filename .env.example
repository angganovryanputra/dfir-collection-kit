# DFIR Rapid Collection Kit — Environment Configuration
# Copy this file to .env and fill in all required values before starting.
# Run scripts/generate-secrets.sh to auto-generate all secret values.

# ==============================================================================
# Database (PostgreSQL)
# ==============================================================================

DATABASE_URL=postgresql+asyncpg://dfir:CHANGE_ME_DB_PASSWORD@db:5432/dfir
POSTGRES_USER=dfir
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=dfir

# ==============================================================================
# Redis (Celery broker + result backend)
# ==============================================================================

REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# ==============================================================================
# Security Secrets (REQUIRED — backend refuses to start with defaults)
# ==============================================================================

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
AGENT_SHARED_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Optional: HMAC key for signing outbound webhook payloads (X-DFIR-Signature header)
WEBHOOK_SECRET=

ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==============================================================================
# User Accounts (created on first startup — idempotent)
# ==============================================================================

DFIR_DEFAULT_ADMIN_PASSWORD=CHANGE_ME_BEFORE_LAUNCH
DFIR_DEFAULT_ANALYST_PASSWORD=
DFIR_DEFAULT_VIEWER_PASSWORD=

# ==============================================================================
# Evidence Storage
# ==============================================================================

EVIDENCE_STORAGE_PATH=/vault/evidence
MAX_FILE_SIZE_GB=50

# ==============================================================================
# Authentication & CORS
# ==============================================================================

REQUIRE_AUTH=true
ALLOWED_ORIGINS=https://localhost

# ==============================================================================
# Demo / Seed Data
# ==============================================================================

# Set true to seed a full demo ransomware incident on startup. DISABLE IN PRODUCTION.
SEED_DEMO_DATA=false

# ==============================================================================
# Frontend
# ==============================================================================

VITE_API_BASE_URL=/api/v1

# ==============================================================================
# Forensics Pipeline Tools
# ==============================================================================

EZTOOLS_DIR=/opt/eztools
HAYABUSA_PATH=/opt/hayabusa/hayabusa
CHAINSAW_PATH=/opt/chainsaw/chainsaw
SIGMA_RULES_DIR=/opt/chainsaw/rules/
YARA_RULES_DIR=

# ==============================================================================
# S3 / Object Storage (optional)
# ==============================================================================

S3_ENABLED=false
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# ==============================================================================
# Threat Intelligence (optional — R-12)
# ==============================================================================

# VirusTotal API key — enables hash/IP/domain enrichment
VIRUSTOTAL_API_KEY=

# MISP threat intel platform
MISP_URL=
MISP_API_KEY=

# ==============================================================================
# AI / LLM Annotation (optional — R-6)
# OpenAI-compatible endpoint; point to Ollama for local/offline deployment
# ==============================================================================

LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ==============================================================================
# Case Management Integrations (optional — R-13)
# ==============================================================================

# TheHive
THEHIVE_URL=
THEHIVE_API_KEY=

# Jira
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=DFIR

# Slack real-time alerts
SLACK_WEBHOOK_URL=

# ==============================================================================
# Notification Webhooks
# ==============================================================================

NOTIFICATION_WEBHOOK_URL=

# ==============================================================================
# Production Checklist
# ==============================================================================
#
# [ ] SECRET_KEY and AGENT_SHARED_SECRET set to random values
# [ ] POSTGRES_PASSWORD and REDIS_PASSWORD set (not defaults)
# [ ] DFIR_DEFAULT_ADMIN_PASSWORD set
# [ ] SEED_DEMO_DATA=false
# [ ] REQUIRE_AUTH=true
# [ ] ALLOWED_ORIGINS set to your actual domain
# [ ] TLS certificates installed in nginx/certs/
# [ ] S3 or local volume configured for evidence storage backups
