# DFIR Rapid Collection Kit - Environment Configuration
# Copy this file to .env and configure values before running

# ==============================================================================
# Backend Configuration
# ==============================================================================

# Database connection URL
# For Docker (recommended): postgresql+asyncpg://dfir:dfir@db:5432/dfir
# For local dev: postgresql+asyncpg://dfir:password@localhost:5432/dfir
DATABASE_URL=postgresql+asyncpg://dfir:dfir@db:5432/dfir

# Secret key for JWT token signing (REQUIRED — must be changed before starting)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# The backend will refuse to start with known weak defaults (change-me, local-dev-secret, etc.)
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# Agent shared secret for agent authentication (REQUIRED — must be changed before starting)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Must match the agent's --secret flag or AGENT_SHARED_SECRET env var
AGENT_SHARED_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# JWT token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Path to store evidence files
EVIDENCE_STORAGE_PATH=/vault/evidence

# Maximum evidence upload size in megabytes
MAX_UPLOAD_SIZE_MB=10240

# Require authentication for API endpoints
# Set to false ONLY for local development
REQUIRE_AUTH=true

# Admin account password (default: admin123!)
# Override before first launch to set a custom password
DFIR_DEFAULT_ADMIN_PASSWORD=admin123!

# ==============================================================================
# Demo / Feature Testing
# ==============================================================================

# Set to true to auto-seed a complete "CORAL REEF" ransomware demo incident on
# container startup. Seeds incident INC-MOCK-SUPERTL, 7 devices, 2 collectors,
# evidence folders, and builds the Super Timeline. Idempotent — safe to restart.
#
# To remove demo data afterwards:
#   docker compose run --rm backend python app/seed_demo.py --clean
#
# Set back to false (or remove) before using in production.
SEED_DEMO_DATA=true

# Allowed CORS origins for frontend
# For Docker: http://localhost:5173
# For production: https://your-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# ==============================================================================
# Frontend Configuration
# ==============================================================================

# Backend API base URL
# For Docker (recommended): http://backend:8000/api/v1
# For local dev: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://backend:8000/api/v1

# ==============================================================================
# Forensics Pipeline (Scalable Forensics)
# ==============================================================================

# Path to directory containing EZTools binaries (EvtxECmd, MFTECmd, RECmd, etc.)
# Default in Docker: /opt/eztools (auto-installed in Dockerfile)
# For local dev: download from https://ericzimmerman.github.io and set path
EZTOOLS_DIR=/opt/eztools

# Path to Hayabusa binary (Windows Event Log fast forensics analyzer)
# Default in Docker: /opt/hayabusa/hayabusa
HAYABUSA_PATH=/opt/hayabusa/hayabusa

# Path to Chainsaw binary (rapid Windows EVTX triage tool)
# Default in Docker: /opt/chainsaw/chainsaw
CHAINSAW_PATH=/opt/chainsaw/chainsaw

# Path to Sigma rules directory used by Chainsaw
# Default in Docker: /opt/chainsaw/rules/
SIGMA_RULES_DIR=/opt/chainsaw/rules/

# ==============================================================================
# Production Notes
# ==============================================================================
#
# 1. SECRET_KEY and AGENT_SHARED_SECRET must be set to strong random values
# 2. REQUIRE_AUTH should always be true in production
# 3. ALLOWED_ORIGINS should be set to your actual frontend domain
# 4. Evidence storage should be backed up regularly
# 5. Consider using external object storage for large deployments
# 6. Install EZTools, Hayabusa, and Chainsaw for forensics pipeline support
