DATABASE_URL=postgresql+asyncpg://dfir:dfir@localhost:5432/dfir

# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# The backend will refuse to start with known weak defaults when REQUIRE_AUTH=true
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_VERSION=dev
ALLOWED_ORIGINS=http://localhost:5173
EVIDENCE_STORAGE_PATH=/vault/evidence
MAX_UPLOAD_SIZE_MB=10240

# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_SHARED_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

REQUIRE_AUTH=true

# Seed user passwords — if unset, random passwords are generated and printed to startup logs.
# Set these before first launch so you know the credentials.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
DFIR_DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
DFIR_DEFAULT_OPERATOR_PASSWORD=REPLACE_WITH_STRONG_OPERATOR_PASSWORD
DFIR_DEFAULT_VIEWER_PASSWORD=REPLACE_WITH_STRONG_VIEWER_PASSWORD
# Demo users (J.SMITH, M.CHEN, K.JOHNSON, R.WILLIAMS) share this password
DFIR_SEED_PASSWORD=REPLACE_WITH_DEMO_PASSWORD
