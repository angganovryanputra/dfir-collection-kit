DATABASE_URL=postgresql+asyncpg://dfir:dfir@localhost:5432/dfir

# ── Docker Compose PostgreSQL (not used for local uvicorn dev) ───────────────
# REQUIRED for docker compose: generate with scripts/generate-secrets.sh
POSTGRES_USER=dfir
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DB=dfir

# ── Application secrets ───────────────────────────────────────────────────────
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# The backend will refuse to start with known weak defaults when REQUIRE_AUTH=true
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_VERSION=dev
ALLOWED_ORIGINS=http://localhost:5173
EVIDENCE_STORAGE_PATH=/vault/evidence
MAX_UPLOAD_SIZE_MB=10240

# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_SHARED_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

REQUIRE_AUTH=true

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED: Redis password for broker authentication
REDIS_PASSWORD=CHANGE_ME_REDIS

# ── Seed accounts ─────────────────────────────────────────────────────────────
# REQUIRED: Change before first launch. The backend will use this as the admin account password.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
DFIR_DEFAULT_ADMIN_PASSWORD=CHANGE_ME_BEFORE_LAUNCH
DFIR_DEFAULT_ANALYST_PASSWORD=
DFIR_DEFAULT_VIEWER_PASSWORD=
